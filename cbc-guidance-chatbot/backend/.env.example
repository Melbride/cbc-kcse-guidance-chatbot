# Required API Keys for CBC Guidance System
# Copy this file to .env and fill in your actual API keys

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=cbc-guidance-docs

# Groq LLM for answer generation
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace for embeddings (alternative to local)
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# Database Configuration (if using PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/cbc_guidance

# Optional: OpenAI (alternative LLM)
# OPENAI_API_KEY=your_openai_key_here
